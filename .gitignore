# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
!terraform.tfvars.example
# Allow specific non-secret tfvars to be tracked (Jenkins clones from git
# and needs them to terraform plan/apply). These files must NOT contain
# secrets — only environment config (cluster name, instance types, etc.).
!envs/test/ops/stacks/golang-eks/terraform.tfvars
!envs/test/ops/stacks/golang-eks-workload/terraform.tfvars
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Plan outputs
*.tfplan
plan.json
plan.md

# Backup
*.backup
.hermes/
