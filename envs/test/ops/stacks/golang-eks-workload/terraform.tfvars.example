aws_region  = "ap-northeast-1"
environment = "test"

cluster_name = "golang-eks-cluster-1"

# Helm release: golang-app
release_name  = "golang-app"
namespace     = "default"
replica_count = 3

# Container image (ECR)
image_repository = "151062088992.dkr.ecr.ap-northeast-1.amazonaws.com/golang-app"
image_tag        = "v1.0.0"
container_port   = 8082
service_port     = 80

# Per-pod resources: 1C / 1Gi (requests = limits)
cpu    = "1000m"
memory = "1Gi"
